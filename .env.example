# ===========================================
# Docker Architecture
# ===========================================
DOCKER_ARCH=arm64

# ===========================================
# LLM Provider (at least one required)
# ===========================================
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_TOKEN=
# OPENAI_API_KEY=

# Local/custom OpenAI-compatible endpoint (e.g. Ollama, vLLM, LM Studio)
# CUSTOM_LLM_BASE_URL=http://host.docker.internal:11434/v1
# CUSTOM_LLM_API_KEY=

# ===========================================
# Tool API Keys (optional)
# ===========================================
# EXA_API_KEY=
# FIRECRAWL_API_KEY=
# FAL_KEY=
# PARALLEL_API_KEY=

# ===========================================
# Messaging Gateway (optional)
# ===========================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_ALLOWED_USERS=

# ===========================================
# GitHub
# ===========================================
# Personal access token (simple)
# GITHUB_TOKEN=

# ===========================================
# Misc
# ===========================================
# HONCHO_API_KEY=
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
